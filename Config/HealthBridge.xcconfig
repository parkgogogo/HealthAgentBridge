HEALTH_REPORTER_WIDGET_BUNDLE_IDENTIFIER = com.example.HealthReporter.DataTrackerWidgetExtension
HEALTH_REPORTER_APP_GROUP = group.com.example.HealthReporter
HEALTH_BRIDGE_MAC_BUNDLE_IDENTIFIER = com.example.HealthBridgeMac

#include? "Local.xcconfig"
