<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>Data Tracker</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>HealthBridgeSharedToken</key>
	<string>$(HEALTH_BRIDGE_SHARED_TOKEN)</string>
	<key>HealthBridgeTailnetHost</key>
	<string>$(HEALTH_BRIDGE_TAILNET_HOST)</string>
	<key>HealthBridgeTailnetIPv4</key>
	<string>$(HEALTH_BRIDGE_TAILNET_IPV4)</string>
	<key>HealthReporterAppGroup</key>
	<string>$(HEALTH_REPORTER_APP_GROUP)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSBonjourServices</key>
	<array>
		<string>_healthbridge._tcp</string>
	</array>
	<key>NSHealthShareUsageDescription</key>
	<string>用于读取你的健康数据，并上报到你自己的 Mac 本地健康桥接服务。</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>用于把你通过本地 Agent 记录的体重和饮食数据写入 Apple Health。</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>用于在本地网络中发现并连接你的 Mac 健康桥接服务。</string>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
